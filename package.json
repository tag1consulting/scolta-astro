{
  "name": "scolta-astro",
  "version": "1.0.0",
  "description": "Scolta integration for Astro — AI-powered Pagefind search",
  "license": "MIT",
  "author": "Tag1 Consulting <info@tag1.com>",
  "homepage": "https://tag1.com",
  "keywords": [
    "search",
    "ai",
    "pagefind",
    "astro"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/integration.cjs",
  "module": "./dist/integration.js",
  "types": "./dist/integration.d.ts",
  "exports": {
    ".": {
      "types": "./dist/integration.d.ts",
      "import": "./dist/integration.js",
      "require": "./dist/integration.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./build": {
      "types": "./dist/build.d.ts",
      "import": "./dist/build.js",
      "require": "./dist/build.cjs"
    },
    "./routes/expand-query": {
      "types": "./dist/routes/expand-query.d.ts",
      "default": "./dist/routes/expand-query.js"
    },
    "./routes/summarize": {
      "types": "./dist/routes/summarize.d.ts",
      "default": "./dist/routes/summarize.js"
    },
    "./routes/followup": {
      "types": "./dist/routes/followup.d.ts",
      "default": "./dist/routes/followup.js"
    },
    "./routes/health": {
      "types": "./dist/routes/health.d.ts",
      "default": "./dist/routes/health.js"
    },
    "./ScoltaSearch.astro": "./ScoltaSearch.astro",
    "./package.json": "./package.json"
  },
  "bin": {
    "scolta-build": "./dist/cli.js"
  },
  "files": [
    "dist",
    "ScoltaSearch.astro",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "scolta": "^1.0.0"
  },
  "peerDependencies": {
    "astro": ">=4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.8"
  }
}
