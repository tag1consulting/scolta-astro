{
  "name": "scolta-astro",
  "version": "1.0.0",
  "description": "Scolta integration for Astro — AI-powered Pagefind search",
  "license": "MIT",
  "author": "Tag1 Consulting <info@tag1.com>",
  "homepage": "https://tag1.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tag1consulting/scolta-astro.git"
  },
  "bugs": {
    "url": "https://github.com/tag1consulting/scolta-astro/issues"
  },
  "keywords": [
    "search",
    "ai",
    "pagefind",
    "astro"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/integration.cjs",
  "module": "./dist/integration.js",
  "types": "./dist/integration.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/integration.d.ts",
        "default": "./dist/integration.js"
      },
      "require": {
        "types": "./dist/integration.d.cts",
        "default": "./dist/integration.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./build": {
      "import": {
        "types": "./dist/build.d.ts",
        "default": "./dist/build.js"
      },
      "require": {
        "types": "./dist/build.d.cts",
        "default": "./dist/build.cjs"
      }
    },
    "./routes/expand-query": {
      "types": "./dist/routes/expand-query.d.ts",
      "default": "./dist/routes/expand-query.js"
    },
    "./routes/summarize": {
      "types": "./dist/routes/summarize.d.ts",
      "default": "./dist/routes/summarize.js"
    },
    "./routes/followup": {
      "types": "./dist/routes/followup.d.ts",
      "default": "./dist/routes/followup.js"
    },
    "./routes/health": {
      "types": "./dist/routes/health.d.ts",
      "default": "./dist/routes/health.js"
    },
    "./ScoltaSearch.astro": "./ScoltaSearch.astro",
    "./package.json": "./package.json"
  },
  "bin": {
    "scolta-build": "dist/cli.js"
  },
  "files": [
    "dist",
    "ScoltaSearch.astro",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsup --config tsup.routes.config.ts",
    "test": "vitest run && vitest run --config vitest.mount.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:publish": "publint && attw --pack . --entrypoints . core build",
    "check:pack": "node scripts/check-pack-content.mjs"
  },
  "dependencies": {
    "scolta": "^1.0.0"
  },
  "peerDependencies": {
    "astro": ">=4"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@eslint/js": "^9.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.11.0",
    "astro": "^6.4.6",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "publint": "^0.3.21",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.6"
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core.d.ts"
      ],
      "build": [
        "./dist/build.d.ts"
      ]
    }
  }
}
